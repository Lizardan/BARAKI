# Local playtest secrets - copy from playtest.env.example and fill in.
# Do not commit this file.
MATCHMAKER_URL=https://baraki-matchmaker.lizard268.workers.dev
REGISTER_SECRET=replace-me
# Required for Discord evenings: named tunnel hostname (no scheme).
# Same value as Discord Developer Portal URL Mapping /wss.
# Setup once: .\infra\scripts\setup-named-tunnel.ps1
WSS_HOST=baraki-game.YOURACCOUNT.cfargotunnel.com
TUNNEL_NAME=baraki-game
# Dev escape hatch only. Leave 0 for Discord playtests.
ALLOW_QUICK_TUNNEL=0
# Optional absolute path to cloudflared.exe if not on PATH:
# CLOUDFLARED_EXE=C:/Tools/cloudflared/cloudflared.exe
# Absolute path to dedicated headless build:
SERVER_EXE=F:/Unity Projects/BARAKI/Builds/WindowsServer/BARAKI.exe
PORT=7777
PLAYERS=2
